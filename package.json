{
  "name": "swarmwatch",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "npm run test && npm run kill:ports && npx concurrently --kill-others-on-fail -n tauri,tests -c green,magenta \"tauri dev\" \"npm run test:watch\"",
    "kill:ports": "npx tsx scripts/kill-ports.ts",
    "frontend:dev": "vite",
    "sync:assets": "tsx scripts/sync-assets.ts",
    "server": "tsx server/avatar-server.ts",
    "build": "npm test && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "simulate:cursor": "tsx scripts/simulate-cursor.ts",
    "simulate:windsurf": "tsx scripts/simulate-windsurf.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "date-fns": "^4.1.0",
    "lottie-web": "^5.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
